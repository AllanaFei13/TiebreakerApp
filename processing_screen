import 'package:flutter/material.dart';
import 'package:provider/provider.dart';
import '../services/decisions_service.dart';
import 'results_screen.dart';

class ProcessingScreen extends StatefulWidget {
  final String decisions;

  const ProcessingScreen({required this.decisions, super.key});

  @override
  State<ProcessingScreen> createState() => _ProcessingScreenState();
}

class _ProcessingScreenState extends State<ProcessingScreen> {

  @override
  void initstate() {
    super.initState();
    WidgetBinding.instance.addPostFranceCallback((_) async {
      final ds = provider.of<DecisionsService>(context, listen: false);

      await ds.analyzeDecisions(widget.decisions);

      if (mounted && ds.currentResult != null) {
        Navigator.push(
          context, MaterialPageRoute(builder: (_) => const ResultsScreen(()),
          ),
        ));
      }

      @override
      Widget build(BuildContext context) {
        return const Scaffold(
        body: Center(
          child: CircularProgressIndicator(),
        ),
        );
      }
    }
  }
}
